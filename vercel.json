{
  "buildCommand": "npm run build",
  "outputDirectory": "dist",
  "installCommand": "npm install",
  "rootDirectory": "web-client",
  "regions": [
    "sin1",
    "hkg1", 
    "fra1",
    "iad1",
    "pdx1",
    "gru1",
    "sfo1",
    "lhr1",
    "nrt1",
    "syd1",
    "bom1",
    "cpt1",
    "dub1"
  ],
  "env": {
    "NODE_ENV": "production",
    "VITE_APP_ENV": "production",
    "VITE_API_BASE_URL": "@api_base_url",
    "VITE_SWARM_API_URL": "@swarm_api_url",
    "VITE_PAYMENT_API_URL": "@payment_api_url",
    "VITE_PRODUCTION_URL": "@production_url",
    "VITE_ENABLE_ANALYTICS": "true",
    "VITE_ENABLE_SENTRY": "true",
    "VITE_SENTRY_DSN": "@sentry_dsn",
    "VITE_GOOGLE_ANALYTICS_ID": "@google_analytics_id",
    "VITE_STRIPE_PUBLISHABLE_KEY": "@stripe_publishable_key",
    "VITE_ENABLE_SWARM": "true",
    "VITE_ENABLE_PAYMENTS": "true",
    "VITE_GLOBAL_OPTIMIZATION": "true",
    "VITE_EDGE_COMPUTING": "true",
    "VITE_LATENCY_TARGET": "0.1ms",
    "VITE_WORLDWIDE_DEPLOYMENT": "true",
    "VITE_GLOBAL_REPLICATION": "true",
    "VITE_COUNTRIES_SUPPORTED": "256",
    "VITE_LANGUAGES_SUPPORTED": "100",
    "VITE_GLOBAL_CURRENCIES": "30",
    "VITE_PAYMENT_METHODS": "5",
    "VITE_GLOBAL_REGIONS": "12",
    "VITE_ENABLE_TELEGRAM": "true",
    "VITE_TELEGRAM_BOT_USERNAME": "@telegram_bot_username",
    "VITE_SUPPORT_EMAIL": "@support_email",
    "VITE_SUPPORT_PHONE": "@support_phone",
    "VITE_COMPANY_NAME": "DEDAN WorldMine",
    "VITE_COMPANY_WEBSITE": "@company_website",
    "VITE_PRIVACY_POLICY": "@privacy_policy_url",
    "VITE_TERMS_OF_SERVICE": "@terms_of_service_url",
    "VITE_COOKIE_POLICY": "@cookie_policy_url",
    "VITE_GDPR_COMPLIANT": "true",
    "VITE_CCPA_COMPLIANT": "true",
    "VITE_DATA_PROTECTION": "true"
  },
  "functions": {
    "api/**/*.js": {
      "runtime": "nodejs18.x",
      "memory": 1024,
      "maxDuration": 30,
      "regions": [
        "sin1", "hkg1", "fra1", "iad1", "pdx1", 
        "gru1", "sfo1", "lhr1", "nrt1", "syd1",
        "bom1", "cpt1", "dub1"
      ]
    },
    "swarm/**/*.js": {
      "runtime": "nodejs18.x",
      "memory": 2048,
      "maxDuration": 60,
      "regions": [
        "sin1", "hkg1", "fra1", "iad1", "pdx1",
        "gru1", "sfo1", "lhr1", "nrt1", "syd1",
        "bom1", "cpt1", "dub1"
      ]
    }
  },
  "rewrites": [
    { "source": "/api/(.*)", "destination": "/api/$1" },
    { "source": "/swarm/(.*)", "destination": "/swarm/$1" },
    { "source": "/payments/(.*)", "destination": "/payments/$1" },
    { "source": "/(.*)", "destination": "/index.html" }
  ],
  "headers": [
    {
      "source": "/(.*)",
      "headers": [
        {
          "key": "X-Edge-Location",
          "value": "enabled"
        },
        {
          "key": "X-Latency-Target",
          "value": "0.1ms"
        },
        {
          "key": "X-Global-Optimization",
          "value": "true"
        },
        {
          "key": "X-Worldwide-Reach",
          "value": "256-countries"
        },
        {
          "key": "Cache-Control",
          "value": "public, max-age=31536000, immutable"
        }
      ]
    },
    {
      "source": "/api/(.*)",
      "headers": [
        {
          "key": "X-API-Edge-Optimization",
          "value": "enabled"
        },
        {
          "key": "X-Latency-Target",
          "value": "0.1ms"
        },
        {
          "key": "Access-Control-Allow-Origin",
          "value": "*"
        },
        {
          "key": "Access-Control-Allow-Methods",
          "value": "GET, POST, PUT, DELETE, OPTIONS"
        },
        {
          "key": "Access-Control-Allow-Headers",
          "value": "Content-Type, Authorization"
        }
      ]
    },
    {
      "source": "/swarm/(.*)",
      "headers": [
        {
          "key": "X-Swarm-Edge-Optimization",
          "value": "enabled"
        },
        {
          "key": "X-Latency-Target",
          "value": "0.1ms"
        },
        {
          "key": "X-Global-Domination",
          "value": "active"
        },
        {
          "key": "Cache-Control",
          "value": "no-cache, no-store, must-revalidate"
        }
      ]
    },
    {
      "source": "/payments/(.*)",
      "headers": [
        {
          "key": "X-Payment-Edge-Optimization",
          "value": "enabled"
        },
        {
          "key": "X-Latency-Target",
          "value": "0.1ms"
        },
        {
          "key": "X-Currency-Conversion",
          "value": "real-time"
        },
        {
          "key": "Cache-Control",
          "value": "no-cache, no-store, must-revalidate"
        }
      ]
    },
    {
      "source": "/sw.js",
      "headers": [
        {
          "key": "Cache-Control",
          "value": "public, max-age=0, must-revalidate"
        }
      ]
    },
    {
      "source": "/manifest.json",
      "headers": [
        {
          "key": "Cache-Control",
          "value": "public, max-age=31536000, immutable"
        }
      ]
    }
  ],
  "edge": {
    "runtime": "nodejs18.x",
    "regions": [
      "sin1", "hkg1", "fra1", "iad1", "pdx1",
      "gru1", "sfo1", "lhr1", "nrt1", "syd1",
      "bom1", "cpt1", "dub1"
    ]
  },
  "build": {
    "env": {
      "VITE_EDGE_OPTIMIZATION": "enabled",
      "VITE_GLOBAL_LATENCY_TARGET": "0.1ms",
      "VITE_WORLDWIDE_DEPLOYMENT": "enabled",
      "VITE_GLOBAL_REPLICATION": "enabled"
    }
  }
}
