# API Configuration
REACT_APP_API_URL=https://dedan-mine-api.koyeb.app
REACT_APP_WS_URL=wss://dedan-mine-api.koyeb.app

# Analytics (FREE)
REACT_APP_GA_ID=G-XXXXXXXXXX

# Feature Flags
REACT_APP_ENABLE_ANALYTICS=true
REACT_APP_ENABLE_SENTRY=true
REACT_APP_ENABLE_CHAT=true
REACT_APP_ENABLE_PAYMENTS=true
REACT_APP_ENABLE_TRADING=true

# Environment
REACT_APP_ENV=production

# Development
REACT_APP_DEBUG=false
REACT_APP_LOG_LEVEL=info

# Third-party Services
REACT_APP_STRIPE_PUBLISHABLE_KEY=pk_test_...
REACT_APP_CHAPA_PUBLIC_KEY=CHASE_TEST_KEY

# Map Services (FREE)
REACT_APP_MAPBOX_TOKEN=pk.eyJ1Ijoi...

# Social Media (Optional)
REACT_APP_TWITTER_HANDLE=dedanmine
REACT_APP_FACEBOOK_URL=https://facebook.com/dedanmine
REACT_APP_INSTAGRAM_HANDLE=dedanmine

# Support
REACT_APP_SUPPORT_EMAIL=support@dedanmine.com
REACT_APP_HELP_URL=https://help.dedanmine.com

# Legal
REACT_APP_PRIVACY_URL=https://dedanmine.com/privacy
REACT_APP_TERMS_URL=https://dedanmine.com/terms
