# ===========================================
# WORLDMINE ENVIRONMENT VARIABLES
# ===========================================
# Copy this file to .env and fill in your values
# Add .env to .gitignore before committing

# ===========================================
# APPLICATION CONFIGURATION
# ===========================================
NEXT_PUBLIC_APP_URL=https://worldmine.vercel.app
NEXT_PUBLIC_APP_NAME=Worldmine
NEXT_PUBLIC_APP_VERSION=1.0.0

# ===========================================
# AUTHENTICATION & SECURITY
# ===========================================
NEXT_PUBLIC_ADMIN_USER_ID=your-admin-user-id-here
NEXT_PUBLIC_AUTH_SECRET=your-super-secret-auth-key-here
WEB_AUTHN_ORIGIN=https://worldmine.vercel.app

# ===========================================
# DATABASE (SUPABASE)
# ===========================================
# Public keys (safe for client-side)
NEXT_PUBLIC_SUPABASE_URL=https://your-project.supabase.co
NEXT_PUBLIC_SUPABASE_ANON_KEY=your-supabase-anon-key-here

# Server keys (NEVER expose to client)
SUPABASE_SERVICE_ROLE_KEY=your-supabase-service-role-key-here
SUPABASE_URL=https://your-project.supabase.co
SUPABASE_ANON_KEY=your-supabase-anon-key-here

# ===========================================
# SECURITY & FRAUD DETECTION
# ===========================================
NEXT_PUBLIC_STRIPE_PUBLISHABLE_KEY=pk_live_your_stripe_publishable_key
STRIPE_SECRET_KEY=sk_live_your_stripe_secret_key
CHAPA_API_KEY=your_chapa_api_key_here

# ===========================================
# EXTERNAL APIS
# ===========================================
NEXT_PUBLIC_OPENAI_API_KEY=sk-your-openai-api-key
ANTHROPIC_API_KEY=your-anthropic-api-key
TAVILY_API_KEY=your-tavily-api-key

# ===========================================
# COMPLIANCE & MONITORING
# ===========================================
COMPLIANCE_WEBHOOK_URL=https://your-webhook-endpoint.com
GDPR_WEBHOOK_URL=https://your-gdpr-webhook-endpoint.com
DATA_RETENTION_DAYS=365

# ===========================================
# VERCEL DEPLOYMENT
# ===========================================
VERCEL_ENV=production
VERCEL_URL=worldmine.vercel.app
VERCEL_PROJECT_PRODUCTION_URL=https://worldmine.vercel.app

# ===========================================
# PERFORMANCE & CACHING
# ===========================================
NEXT_PUBLIC_CACHE_MAX_AGE=3600
NEXT_PUBLIC_SW_VERSION=1.0.0

# ===========================================
# DEBUG & DEVELOPMENT
# ===========================================
NODE_ENV=production
LOG_LEVEL=info
DEBUG=false
