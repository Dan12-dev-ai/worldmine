# AI Translation Service
OPENAI_API_KEY=your_openai_api_key_here

# Authentication & Security
AUTH_SECRET=your_jwt_secret_here
WEB_AUTHN_ORIGIN=https://yourdomain.com

# Database (Supabase)
VITE_SUPABASE_URL=your_supabase_url_here
VITE_SUPABASE_ANON_KEY=your_supabase_anon_key_here
SUPABASE_SERVICE_ROLE_KEY=your_supabase_service_role_key_here

# Security & Fraud Detection
FRAUD_DETECTION_API_KEY=your_fraud_detection_api_key_here
IP_GEOLOCATION_API_KEY=your_ip_geolocation_api_key_here

# Application
NODE_ENV=production
VITE_APP_NAME=Worldmine Marketplace
VITE_APP_VERSION=2.0.0

# Optional: External Services
VITE_STRIPE_PUBLISHABLE_KEY=your_stripe_publishable_key_here
STRIPE_SECRET_KEY=your_stripe_secret_key_here

# Email Service (for 2FA)
SMTP_HOST=your_smtp_host_here
SMTP_PORT=587
SMTP_USER=your_smtp_username_here
SMTP_PASS=your_smtp_password_here

# Monitoring & Analytics
VITE_SENTRY_DSN=your_sentry_dsn_here
GOOGLE_ANALYTICS_ID=your_google_analytics_id_here
